# MCP-Gateway environment variables
# Copy to ~/.env and fill in real values. Never commit this file with real tokens.

# Gateway
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8200
GATEWAY_LOG_LEVEL=INFO

# Module: telegram_user (Pyrogram)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TG_MANAGER_SESSION_DIR=~/.telegram-sessions
TG_MANAGER_RATE_LIMIT=20

# Module: telegram_bot (Bot API)
TELEGRAM_BOT_TOKEN=
